<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace = dao/mapper 接口的全限定名 -->
<mapper namespace="com.neu.mapper.UserMapper">

    <!-- 查询所有：id=方法名, resultType=返回值类型 -->
    <select id="findAll" resultType="com.neu._01hello.vo.UserVO">
        SELECT id, name, money FROM t_user
    </select>

    <!-- 按id查询：parameterType=参数类型, #{} 占位符 -->
    <select id="findById" parameterType="int" resultType="com.neu._01hello.vo.UserVO">
        SELECT id, name, money FROM t_user WHERE id = #{id}
    </select>

    <!-- 登录：多参数查询，使用 @Param 或 Map -->
    <select id="login" resultType="com.neu._01hello.vo.UserVO">
        SELECT id, name, money FROM t_user
        WHERE name = #{name} AND password = #{xx}
    </select>

    <!-- 新增：parameterType 为 domain 对象 -->
    <insert id="add" parameterType="com.neu.domain.User">
        INSERT INTO t_user (name, password, money)
        VALUES (#{name}, #{password}, #{money})
    </insert>

    <!-- 按id删除 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM t_user WHERE id = #{id}
    </delete>

    <!-- 更新 -->
    <update id="update" parameterType="com.neu.domain.User">
        UPDATE t_user
        SET name = #{name}, password = #{password}, money = #{money}
        WHERE id = #{id}
    </update>

</mapper>
