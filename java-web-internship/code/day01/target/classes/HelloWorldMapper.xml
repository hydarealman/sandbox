<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace = dao 接口的全限定名 -->
<mapper namespace="com.neu._01hello.dao.UserDao">
    <!-- id = 方法名, resultType = 返回值类型 -->
    <select id="find" resultType="com.neu._01hello.vo.UserVO">
        SELECT id, name, money FROM t_user
    </select>
</mapper>
